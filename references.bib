@inproceedings{alturkestani_maximizing_2020,
	address = {Cham},
	title = {Maximizing {I}/{O} {Bandwidth} for {Reverse} {Time} {Migration} on {Heterogeneous} {Large}-{Scale} {Systems}},
	isbn = {978-3-030-57675-2},
	doi = {10.1007/978-3-030-57675-2_17},
	abstract = {Reverse Time Migration (RTM) is an important scientific application for oil and gas exploration. The 3D RTM simulation generates terabytes of intermediate data that does not fit in main memory. In particular, RTM has two successive computational phases, i.e., the forward modeling and the backward propagation, that necessitate to write and then to read the state of the computed solution grid at specific time steps of the time integration. Advances in memory architecture have made it feasible and affordable to integrate hierarchical storage media on large-scale systems, starting from the traditional Parallel File Systems (PFS) to intermediate fast disk technologies (e.g., node-local and remote-shared Burst Buffer) and up to CPU main memory. To address the trend of heterogeneous HPC systems deployment, we introduce an extension to our Multilayer Buffer System (MLBS) framework to further maximize RTM I/O bandwidth in presence of GPU hardware accelerators. The main idea is to leverage the GPU’s High Bandwidth Memory (HBM) as an additional storage media layer. The objective of MLBS is ultimately to hide the application’s I/O overhead by enabling a buffering mechanism operating across all the hierarchical storage media layers. MLBS is therefore able to sustain the I/O bandwidth at each storage media layer. By asynchronously performing expensive I/O operations and creating opportunities for overlapping data motion with computations, MLBS may transform the original I/O bound behavior of the RTM application into a compute-bound regime. In fact, the prefetching strategy of MLBS allows the RTM application to believe that it has access to a larger memory capacity on the GPU, while transparently performing the necessary housekeeping across the storage layers. We demonstrate the effectiveness of MLBS on the Summit supercomputer using 2048 compute nodes equipped with a total of 12288 GPUs by achieving up to 1.4X performance speedup compared to the reference PFS-based RTM implementation for large 3D solution grid.},
	language = {en},
	booktitle = {Euro-{Par} 2020: {Parallel} {Processing}},
	publisher = {Springer International Publishing},
	author = {Alturkestani, Tariq and Ltaief, Hatem and Keyes, David},
	editor = {Malawski, Maciej and Rzadca, Krzysztof},
	year = {2020},
	keywords = {Asynchronous I/O operations, Heterogeneous systems, Hierarchical storage media, Multilayer Buffer System, Reverse Time Migration},
	pages = {263--278},
	annote = {Esse paper explica como a modificação da técnica de multi layer buffer system (MLBS) para incluir GPUs potencializou a execução da aplicação. Isso inclui técnicas de prefetching e mascaramento de transmissões.

Ele é útil pois dá alguns números da dominância do IO no RTM, assim como explica o porquê disso.
Além disso pode-se fazer um link com o Asynchronous Task-Based Execution of the Reverse Time Migration for the Oil and Gas Industry e a feature OOC do starpu.
},
	file = {Full Text PDF:/home/colle/Zotero/storage/4L8GUNIJ/Alturkestani et al. - 2020 - Maximizing IO Bandwidth for Reverse Time Migration on Heterogeneous Large-Scale Systems.pdf:application/pdf},
}

@inproceedings{kunas_enhancing_2025,
	address = {Cham},
	title = {Enhancing {Reverse} {Time} {Migration} {Simulations} in {HPC} {Systems} {Through} {I}/{O} and {Computation} {Overlapping}},
	isbn = {978-3-031-80084-9},
	doi = {10.1007/978-3-031-80084-9_5},
	abstract = {The evaluation of scientific simulation applications is crucial for their efficiency and effectiveness. Managing input and output (I/O) operations in seismic simulations represents a significant challenge. The Fletcher Reverse Time Migration (RTM) algorithm is a prime example, where synchronous I/O operations pause computation to store data on disk, which is necessary for saving simulation checkpoints. This approach leads to idle CPU and GPU periods, significantly affecting the simulation time, especially in long-term or high-resolution simulations. This paper examines the performance of the Fletcher RTM algorithm, with a particular focus on the impact of I/O operations. It explores the potential for overlapping computation with I/O to optimize execution, allowing continued data processing while asynchronously saving checkpoints. This strategy can reduce idle periods and enhance efficiency, particularly in environments where efficient management of compute-intensive tasks and data I/O operations is essential, such as modern data centers, cloud computing, and high-performance computing (HPC) systems.},
	language = {en},
	booktitle = {High {Performance} {Computing}},
	publisher = {Springer Nature Switzerland},
	author = {Künas, Cristiano A. and Freytag, Gabriel and Navaux, Philippe O. A.},
	editor = {Guerrero, Ginés and San Martín, Jaime and Meneses, Esteban and Barrios Hernández, Carlos Jaime and Osthoff, Carla and Monsalve Diaz, Jose M.},
	year = {2025},
	keywords = {Compute and I/O overlap, HPC, I/O, RTM, Seismic Simulation},
	pages = {68--82},
	annote = {Anotações(13/02/2026, 16:47:39)
(Künas et al., 2025, p. 2) Acidentalemente implementamos uma interface optimizada de IO.Com o modelo de flecha, a geração do I/O não trava nenhum recurso, podendo ser computada completamente de forma assíncrona.No momento em que o bloco está disponível para ser salvo até o momento que este é escrito em disco, não há modificações no bloco. Ele apenas será usado como leitura para as exatas duas iterações seguintes e depois liberado automaticamente pelo StarPU. Dessa forma a ação de escrita nunca bloqueia a execução do programa. Pode ocorrer uma possível desaceleração caso uma tarefa de processamento não consiga um core, pois este está ocupado com escrita. Mas como a escrita é um tempo significativamente menor que o processamento do bloco, isso não deve ser significativo.Otimizando IO por engano.“[4] focuses on optimizing Reverse Time Migration (RTM) for seismic imaging, a computationally intensive process widely used in the oil and gas industry. The authors developed a task-based framework, TB-RTM, which leverages the STARPU dynamic runtime system to effectively manage and schedule tasks across heterogeneous GPU-based systems.” (Künas et al., 2025, p. 3) Tá aqui“Their findings reveal optimal configurations that maximize I/O performance, providing valuable insights for developing efficient asynchronous I/O aggregation schemes” (Künas et al., 2025, p. 3) StarPU determina isso dinamicamente
},
	annote = {Esse peper é ótimo pois sua o mesmo domínio que o meu e fala da assincronicidade. É muito bom para apontar que o StarPU e os sistema STF entregam isso de graça.
},
	file = {PDF:/home/colle/Zotero/storage/T58B5T7Q/Künas et al. - 2025 - Enhancing Reverse Time Migration Simulations in HPC Systems Through IO and Computation Overlapping.pdf:application/pdf},
}

@inproceedings{huang_towards_2023,
	title = {Towards {Improving} {Reverse} {Time} {Migration} {Performance} by {High}-speed {Lossy} {Compression}},
	url = {https://ieeexplore.ieee.org/document/10171443/},
	doi = {10.1109/CCGrid57682.2023.00066},
	abstract = {Seismic imaging is an exploration method for estimating the seismic characteristics of the earth's sub-surface for geologists and geophysicists. Reverse time migration (RTM) is a critical method in seismic imaging analysis. It can produce huge volumes of data that need to be stored for later use during its execution. The traditional solution transfers the vast amount of data to peripheral devices and loads them back to memory whenever needed, which may cause a substantial burden to I/O and storage space. As such, an efficient data compressor turns out to be a very critical solution. In order to get the best overall RTM analysis performance, we develop a novel hybrid lossy compression method (called HyZ), which is not only fairly fast in both compression and decompression but also has a good compression ratio with satisfactory reconstructed data quality for post hoc analysis. We evaluate several state-of-the-art error-controlled lossy compression algorithms (including HyZ, BR, SZx, SZ, SZ-Interp, ZFP, etc.) in a supercomputer. Experiments show that HyZ not only significantly improves the overall performance for RTM by 6.29∼6.60× but also obtains fairly good qualities for both RTM single snapshots and the final stacking image.},
	urldate = {2026-02-04},
	booktitle = {2023 {IEEE}/{ACM} 23rd {International} {Symposium} on {Cluster}, {Cloud} and {Internet} {Computing} ({CCGrid})},
